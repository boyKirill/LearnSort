NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/sortlearn
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret-at-least-32-chars
REFRESH_TOKEN_TTL_DAYS=7
ACCESS_TOKEN_TTL_MINUTES=15
FRONTEND_URL=http://127.0.0.1:4173
CORS_ORIGIN=http://localhost:4173,http://127.0.0.1:4173
COOKIE_NAME=sortlearn_refresh
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your-email@gmail.com
VERIFICATION_CODE_TTL_MINUTES=15
BCRYPT_SALT_ROUNDS=12
