DOMAIN=example.com
ACME_EMAIL=admin@example.com
PUBLIC_URL=https://example.com

POSTGRES_DB=sortlearn
POSTGRES_USER=sortlearn
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://sortlearn:change-this-password@postgres:5432/sortlearn

ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret-at-least-32-chars
REFRESH_TOKEN_TTL_DAYS=7
ACCESS_TOKEN_TTL_MINUTES=15
COOKIE_NAME=sortlearn_refresh

MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your-email@gmail.com

VERIFICATION_CODE_TTL_MINUTES=15
BCRYPT_SALT_ROUNDS=12
